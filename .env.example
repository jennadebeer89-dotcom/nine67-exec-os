# --- OpenAI (the AI language layer) ---
# Required for live executive summaries, risk explanations, and ask-the-business chat.
# Without it, the app still runs and serves pre-computed (cached) AI outputs.
OPENAI_API_KEY=sk-...
# Optional: override the model (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# --- Supabase (the data layer) ---
# Optional. Without these the app reads the in-repo messy sample data instead.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key is used server-side for reads and by the seed script.
SUPABASE_SERVICE_ROLE_KEY=ey...
# Anon key (optional) — also works for read-only access if RLS policies are applied.
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
